{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "Node16",
    "moduleResolution": "Node16",

    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
